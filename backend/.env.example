# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tonpred

# ── TON Blockchain ─────────────────────────────────────────────────────────────
# Get a free API key at https://toncenter.com
TON_API_KEY=
TON_NETWORK=testnet
TON_API_URL=https://testnet.toncenter.com/api/v2

# Deployed prediction market smart contract address
PREDICTION_CONTRACT_ADDRESS=
PLATFORM_TON_ADDRESS=
DEPLOYER_MNEMONIC=

# ── Telegram ───────────────────────────────────────────────────────────────────
# Your bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Random secret string for webhook signature verification
TELEGRAM_WEBHOOK_SECRET=
# Full URL of your Mini App (set after BotFather Mini App setup)
MINI_APP_URL=https://t.me/your_bot/app

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list or leave default for Telegram
ALLOWED_ORIGINS=["http://localhost:3000","https://t.me"]

# ── Fees ───────────────────────────────────────────────────────────────────────
# Platform fee in basis points: 200 = 2%
PLATFORM_FEE_BPS=200

# ── Оракулы ───────────────────────────────────────────────────────────────────
# football-data.org (бесплатно, 10 req/мин)
# Регистрация: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# API-Football через RapidAPI (альтернатива)
API_FOOTBALL_KEY=

# Pyth Network и Open-Meteo — без ключа, работают автоматически
